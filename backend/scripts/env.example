# =============================================
# KKOOKK Backend - 환경변수 설정
# 사용법: cp scripts/env.example scripts/.env
# =============================================

# --- Spring ---
SPRING_PROFILES_ACTIVE=prod

# --- Database ---
DB_URL=jdbc:mysql://localhost:3306/kkookkdb?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=kkookkuser
DB_PASSWORD=kkookkpass

# --- JWT ---
JWT_SECRET=your-secret-key-minimum-256-bits-required-change-this-in-production
JWT_ACCESS_TOKEN_EXPIRATION=3600000
JWT_STEPUP_TOKEN_EXPIRATION=600000

# --- App ---
QR_BASE_URL=https://your-domain.com
STORAGE_PATH=/data/storage

# --- Monitoring (선택) ---
LOKI_URL=http://localhost:3100

# Slack Webhook URLs (채널별 분리)
# #alert-critical 채널용 Incoming Webhook
SLACK_WEBHOOK_CRITICAL=
# #alert-warning 채널용 Incoming Webhook
SLACK_WEBHOOK_WARNING=
